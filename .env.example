# NOX Node Secrets
# Generate with: docker run --rm ghcr.io/hisoka-io/nox:0.1.2-testnet keygen
#
# Format: NOX__FIELD_NAME for top-level config fields
#         NOX__SECTION__FIELD_NAME for nested fields
#
# NEVER share private keys. Only share the public values printed by keygen.

NOX__ROUTING_PRIVATE_KEY=
NOX__P2P_PRIVATE_KEY=

# Exit nodes only (relay nodes can leave this empty):
NOX__ETH_WALLET_PRIVATE_KEY=
